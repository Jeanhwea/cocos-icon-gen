{
  "name": "@jeansoft/cocos-icon-gen",
  "version": "0.2.6",
  "description": "Generate iOS, macOS, and Windows app icons for Cocos Creator projects from a single source image",
  "author": "jeansoft",
  "homepage": "https://github.com/Jeanhwea/cocos-icon-gen#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeanhwea/cocos-icon-gen.git"
  },
  "packageManager": "pnpm@10.8.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cocos-icon-gen": "dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --check ."
  },
  "dependencies": {
    "sharp": "^0.33.5",
    "png-to-ico": "^2.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
