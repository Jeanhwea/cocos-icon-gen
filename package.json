{
  "name": "@jeansoft/cocos-icon-gen",
  "version": "0.1.3",
  "description": "Generate app icons (iOS/macOS/Windows) for Cocos projects from a source image",
  "type": "module",
  "bin": {
    "cocos-icon-gen": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\""
  },
  "keywords": [
    "cocos",
    "cocos-creator",
    "app-icon",
    "icon",
    "ios",
    "macos",
    "windows"
  ],
  "author": "jeansoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeanhwea/cocos-icon-gen.git"
  },
  "bugs": {
    "url": "https://github.com/Jeanhwea/cocos-icon-gen/issues"
  },
  "homepage": "https://github.com/Jeanhwea/cocos-icon-gen#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.9.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
